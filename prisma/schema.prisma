generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// =========================
// AUTH MODELS (NextAuth)
// =========================
//

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  password      String?
  emailVerified DateTime?
  image         String?

  role          String          @default("user")

  accounts      Account[]
  sessions      Session[]
  jobs          Job[]           @relation("UserJobs")
  searchHistory SearchHistory[]
  savedSearches SavedSearch[]
  savedGrants   SavedGrant[]
  comparisons   GrantComparison[]
  comments      ComparisonComment[]
  notifications Notification[]

  profile       UserProfile?

  stripeCustomerId String?
  planName         String?
  status           String?
  renewalDate      DateTime?

  // Workspaces
  workspaceMembers WorkspaceMember[]
  workspaceInvites WorkspaceInvite[]

  // Drafts
  grantDrafts      GrantDraft[]

  // Batch 129 additions
  narratives       Narrative[]
  reports          Report[]
  auditLogs        AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//
// =========================
// USER PROFILE MODEL
// =========================
//

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique

  organizationName  String?
  organizationType  String?
  mission           String?
  website           String?

  country           String?
  state             String?
  city              String?

  nonprofitStatus   String?
  ein               String?

  staffSize         Int?
  annualBudget      Int?
  grantExperience   String?

  focusAreas        String[]
  populationsServed String[]
  geographicService String[]

  pastGrants        String?
  pastWins          Int?
  pastLosses        Int?

  strategicGoals    String?
  priorityAreas     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

//
// =========================
// WORKSPACE MODELS
// =========================
//

model Workspace {
  id        String            @id @default(cuid())
  name      String
  createdAt DateTime          @default(now())

  members     WorkspaceMember[]
  invites     WorkspaceInvite[]
  comparisons GrantComparison[]

  // Batch 129 additions
  grants      Grant[]
  budgets     Budget[]
  reports     Report[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("member")
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  invitedById String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  invitedBy User      @relation(fields: [invitedById], references: [id])
}

//
// =========================
// SEARCH HISTORY MODEL
// =========================
//

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//
// =========================
// SAVED SEARCHES MODEL
// =========================
//

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//
// =========================
// JOB SYSTEM MODELS
// =========================
//

model Job {
  id        String     @id @default(cuid())
  text      String
  input     Json?
  status    String     @default("queued")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  logs      JobLog[]
  result    JobResult?

  userId    String?
  user      User?      @relation("UserJobs", fields: [userId], references: [id])
}

model JobLog {
  id        String   @id @default(cuid())
  jobId     String
  message   String
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])
}

model JobResult {
  id        String   @id @default(cuid())
  jobId     String   @unique
  result    Json
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])
}

//
// =========================
// BILLING LOG MODEL
// =========================
//

model BillingLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  createdAt DateTime @default(now())
}

//
// =========================
// GRANT + EMBEDDING MODELS
// =========================
//

model GrantPage {
  id        String      @id @default(cuid())
  url       String      @unique
  title     String?
  content   String?
  createdAt DateTime    @default(now())

  embeddings Embedding[]
}

model Embedding {
  id        String   @id @default(cuid())
  pageId    String
  vector    Float[]
  createdAt DateTime @default(now())

  page GrantPage @relation(fields: [pageId], references: [id])
}

//
// =========================
// GRANT PREVIEW MODEL
// =========================
//

model GrantPreview {
  id        String   @id @default(cuid())
  title     String
  summary   String
  amount    String?
  deadline  String?
  category  String?
  agency    String?
  url       String?
  content   String?

  eligibilityScore Float?
  fitScore         Float?
  riskScore        Float?
  competitiveness  Float?
  fundingStrength  Float?
  overallScore     Float?

  fitExplanation   String?
  risks            String?
  nextSteps        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedBy   SavedGrant[]
}

//
// =========================
// SAVED GRANTS MODEL
// =========================
//

model SavedGrant {
  id        String        @id @default(cuid())
  userId    String
  grantId   String

  title     String
  agency    String?
  url       String?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id])
  grant     GrantPreview  @relation(fields: [grantId], references: [id])
}

//
// =========================
// GRANT COMPARISON MODEL
// =========================
//

model GrantComparison {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  grantIds    String[]
  name        String?  @default("Untitled Comparison")
  analysis    Json?
  sharedWith  String[] @default([])
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  activities ComparisonActivity[]
  comments   ComparisonComment[]
}

model ComparisonActivity {
  id           String   @id @default(cuid())
  comparisonId String
  userId       String?
  action       String
  details      Json?
  createdAt    DateTime @default(now())

  comparison GrantComparison @relation(fields: [comparisonId], references: [id])
}

model ComparisonComment {
  id           String   @id @default(cuid())
  comparisonId String
  userId       String
  text         String
  createdAt    DateTime @default(now())

  comparison   GrantComparison @relation(fields: [comparisonId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
}

//
// =========================
// NOTIFICATIONS
// =========================
//

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//
// =========================
// FEDERAL GRANT INGESTION MODEL
// =========================
//

model FederalGrant {
  id         String   @id @default(cuid())
  externalId String   @unique
  source     String
  title      String
  summary    String?
  agency     String?
  category   String?
  amount     Float?
  deadline   DateTime?
  url        String?
  raw        Json

  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
}

//
// =========================
// INGESTION LOG MODEL
// =========================
//

model IngestionLog {
  id          String   @id @default(cuid())
  source      String
  status      String
  message     String?
  itemCount   Int?
  startedAt   DateTime @default(now())
  finishedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}

//
// =========================
// GRANT DRAFT MODEL
// =========================
//

model GrantDraft {
  id        String   @id @default(cuid())
  userId    String
  grantId   String
  content   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id])
}

//
// =========================
// BATCH 129 — NEW MODELS
// =========================
//

model Grant {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  agency      String?
  summary     String?
  amount      Float?
  deadline    DateTime?
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  narratives Narrative[]
}

model Narrative {
  id        String   @id @default(cuid())
  grantId   String
  userId    String
  section   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grant Grant @relation(fields: [grantId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model Budget {
  id          String   @id @default(cuid())
  workspaceId String
  category    String
  amount      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
